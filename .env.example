# Neon PostgreSQL connection string
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Anthropic API key for AI scoring
ANTHROPIC_API_KEY=sk-ant-...

# Shared dashboard password for authentication
DASHBOARD_PASSWORD=your-secure-password-here

# Session secret (generate a random string)
SESSION_SECRET=your-session-secret-here

# Server port (default: 5000)
PORT=5000

# SendGrid for email (optional)
SENDGRID_API_KEY=SG...

# Cal.com booking URL (optional)
CAL_COM_URL=https://cal.com/keepmodular/feasibility

# OneDrive base folder URL (optional)
ONEDRIVE_FOLDER_BASE_URL=https://keepmodular-my.sharepoint.com/personal/

# Node environment
NODE_ENV=development

# Microsoft Graph API — OAuth (email sync + file access)
MS_TENANT_ID=f2ceb135-e917-463d-b7f9-9b608b6260d2
MS_CLIENT_ID=fd1916a8-e625-4d0f-9e50-970786c33fe5
MS_CLIENT_SECRET=your-client-secret-here
MS_REDIRECT_URI=http://localhost:5000/api/graph/callback

# OneDrive file upload — UPN of the mailbox/OneDrive owner (e.g. clarissa@keepmodular.com)
MS_ONEDRIVE_USER=clarissa@keepmodular.com
